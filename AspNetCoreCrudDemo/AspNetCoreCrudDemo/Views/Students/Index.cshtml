@model IEnumerable<AspNetCoreCrudDemo.Models.Student>

@{
    ViewData["Title"] = "Index";
}

<h1>Öğrenciler</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Öğrenci Oluştur</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.Course)</th>
            <th>@Html.DisplayNameFor(model => model.EnrollmentDate)</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Email)</td>
            <td>@Html.DisplayFor(modelItem => item.Course)</td>
            <td>@Html.DisplayFor(modelItem => item.EnrollmentDate)</td>
            <td>
                <!-- Tag Helper kullanarak a etiketine asp-action ile Controller'daki metoda yol tarif ediyoruz -->
                <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-sm btn-warning">Düzenle</a> |
                <a asp-action="Details" asp-route-id="@item.StudentId" class="btn btn-sm btn-info">Detaylar</a> |
                <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-sm btn-danger">Sil</a>
            </td>
        </tr>
}
    </tbody>
</table>
