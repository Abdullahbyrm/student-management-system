@model AspNetCoreCrudDemo.Models.Student

@{
    ViewData["Title"] = "Detaylar";
}

<h1>Öğrenci Detayı</h1>

<div>
    <h4>Salt Okunur Bilgiler</h4>
    <hr />
    <!-- Veritabanından gelen sadece okunabilen bilgileri dl/dt/dd HTML formunda düzenli gösteriyoruz -->
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Course)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Course)
        </dd>
        
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EnrollmentDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EnrollmentDate)
        </dd>
    </dl>
</div>
<div class="mt-3">
    <!-- Tekrar düzenleme sayfasına bu öğrencinin ID parametresiyle gidebilmesi için link oluşturulması -->
    <a asp-action="Edit" asp-route-id="@Model?.StudentId" class="btn btn-warning">Düzenle</a> |
    <a asp-action="Index">Listeye Geri Dön</a>
</div>
