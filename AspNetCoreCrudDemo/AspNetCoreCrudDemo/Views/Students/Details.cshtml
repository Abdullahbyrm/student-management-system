@model AspNetCoreCrudDemo.Models.Student

@{
    ViewData["Title"] = "Öğrenci Detayı";
    var initials = "";
    var parts = Model.Name.Split(' ');
    if (parts.Length >= 2)
        initials = parts[0][0].ToString().ToUpper() + parts[1][0].ToString().ToUpper();
    else if (parts.Length == 1 && parts[0].Length >= 2)
        initials = parts[0].Substring(0, 2).ToUpper();
}

<div class="page-header fade-in-up">
    <div>
        <h1 class="page-title">Öğrenci Detayı</h1>
        <p class="page-subtitle">@Model.Name adlı öğrencinin bilgileri</p>
    </div>
    <div class="breadcrumb-nav">
        <a href="/"><i class="bi bi-house-door"></i> Dashboard</a> /
        <a asp-action="Index">Öğrenciler</a> / Detay
    </div>
</div>

<div class="detail-card fade-in-up">
    <div class="detail-card-banner">
        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <img src="@Model.PhotoPath" class="student-photo-lg" alt="@Model.Name"
                 style="position:absolute;bottom:-36px;left:2rem;" />
        }
        else
        {
            <div class="detail-avatar">@initials</div>
        }
    </div>
    <div class="detail-card-body">
        <div class="detail-name">@Model.Name</div>
        <div class="detail-role">@Model.Course</div>

        <div class="detail-grid">
            <div>
                <div class="detail-item-label">E-Posta Adresi</div>
                <div class="detail-item-value"><i class="bi bi-envelope me-1" style="color:var(--primary);"></i>@Model.Email</div>
            </div>
            <div>
                <div class="detail-item-label">Kayıt Tarihi</div>
                <div class="detail-item-value"><i class="bi bi-calendar3 me-1" style="color:var(--accent);"></i>@Model.EnrollmentDate.ToString("dd MMMM yyyy")</div>
            </div>
            <div>
                <div class="detail-item-label">Kayıtlı Kurs</div>
                <div class="detail-item-value"><i class="bi bi-book me-1" style="color:var(--warning);"></i>@Model.Course</div>
            </div>
            <div>
                <div class="detail-item-label">Öğrenci ID</div>
                <div class="detail-item-value"><i class="bi bi-hash me-1" style="color:var(--info);"></i>@Model.StudentId</div>
            </div>
        </div>

        <div style="display:flex;gap:0.75rem;margin-top:2rem;">
            <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn-premium warning"><i class="bi bi-pencil-square"></i> Düzenle</a>
            <a asp-action="Index" class="btn-premium outline"><i class="bi bi-arrow-left"></i> Listeye Dön</a>
        </div>
    </div>
</div>
