@model AspNetCoreCrudDemo.Models.Student

@{
    ViewData["Title"] = "Yeni Ekle";
}

<h1>Yeni Öğrenci Ekle</h1>

<h4>Öğrenci Bilgileri</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <!-- asp-action="Create" özelliği, bu formun kontrolcüdeki [HttpPost] Create metoduna gideceğini belirtir -->
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Course" class="control-label"></label>
                <select asp-for="Course" class="form-control">
                    <option value="">-- Lütfen bir kurs seçin --</option>
                    <option value="C# ile .NET Core (Backend)">C# ile .NET Core (Backend)</option>
                    <option value="React & Node.js (Full Stack)">React & Node.js (Full Stack)</option>
                    <option value="Python ile Veri Bilimi (Data Science)">Python ile Veri Bilimi (Data Science)</option>
                    <option value="Java Spring Boot (Kurumsal Web)">Java Spring Boot (Kurumsal Web)</option>
                    <option value="Flutter & Dart (Mobil Uygulama)">Flutter & Dart (Mobil Uygulama)</option>
                </select>
                <span asp-validation-for="Course" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="EnrollmentDate" class="control-label"></label>
                <input asp-for="EnrollmentDate" class="form-control" type="date" />
                <span asp-validation-for="EnrollmentDate" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3 mt-3">
                <input type="submit" value="Kaydet" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Listeye Geri Dön</a>
</div>

<!-- İstemci tarafında sayfa yenilenmeden hataları göstermek için gerekli betikler. (Phase 7 için zemin hazırlığı) -->
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
