@model AspNetCoreCrudDemo.Models.Student

@{
    ViewData["Title"] = "Kaydı Sil";
}

<h1>Kaydı Veritabanından Sil</h1>

<h3>Bu öğrenciyi kalıcı olarak silmek istediğinizden emin misiniz?</h3>
<div>
    <h4>Silinecek Bilgiler</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
    </dl>
    
    <!-- Geri dönüşü olmayan işlemi ancak bir Form üzerinden (POST) kullanarak gerçekleştirebiliriz -->
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="StudentId" />
        <input type="submit" value="Evet, Temelli Sil!" class="btn btn-danger" /> |
        <a asp-action="Index">Hayır, Listeye Geri Dön</a>
    </form>
</div>
