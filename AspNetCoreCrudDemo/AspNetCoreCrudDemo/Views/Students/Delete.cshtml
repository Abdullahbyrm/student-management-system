@model AspNetCoreCrudDemo.Models.Student

@{
    ViewData["Title"] = "Öğrenci Sil";
}

<div class="page-header fade-in-up">
    <div>
        <h1 class="page-title">Öğrenci Kaydını Sil</h1>
        <p class="page-subtitle">Bu işlem geri alınamaz</p>
    </div>
    <div class="breadcrumb-nav">
        <a href="/"><i class="bi bi-house-door"></i> Dashboard</a> /
        <a asp-action="Index">Öğrenciler</a> / Sil
    </div>
</div>

<div class="delete-card fade-in-up">
    <div class="delete-card-top">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <h2>Dikkat! Kalıcı Silme İşlemi</h2>
        <p style="font-size:0.85rem;opacity:0.9;margin-top:0.25rem;">Bu öğrenciyi silmek istediğinizden emin misiniz?</p>
    </div>
    <div class="delete-card-body">
        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <div style="text-align:center;margin-bottom:1rem;">
                <img src="@Model.PhotoPath" style="width:64px;height:64px;border-radius:50%;object-fit:cover;border:3px solid var(--danger);" alt="@Model.Name" />
            </div>
        }
        <div class="delete-info-row">
            <span class="delete-info-label">Öğrenci Adı</span>
            <span class="delete-info-value">@Model.Name</span>
        </div>
        <div class="delete-info-row">
            <span class="delete-info-label">E-Posta</span>
            <span class="delete-info-value">@Model.Email</span>
        </div>
        <div class="delete-info-row">
            <span class="delete-info-label">Kurs</span>
            <span class="delete-info-value">@Model.Course</span>
        </div>
        <div class="delete-info-row">
            <span class="delete-info-label">Kayıt Tarihi</span>
            <span class="delete-info-value">@Model.EnrollmentDate.ToString("dd MMM yyyy")</span>
        </div>

        <form asp-action="Delete" style="margin-top:1.5rem;">
            <input type="hidden" asp-for="StudentId" />
            <div style="display:flex;gap:0.75rem;">
                <button type="submit" class="btn-premium danger"><i class="bi bi-trash3-fill"></i> Evet, Kalıcı Olarak Sil</button>
                <a asp-action="Index" class="btn-premium outline"><i class="bi bi-x-lg"></i> Vazgeç</a>
            </div>
        </form>
    </div>
</div>
