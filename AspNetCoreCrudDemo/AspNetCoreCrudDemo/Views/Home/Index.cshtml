@model IEnumerable<AspNetCoreCrudDemo.Models.Course>

@{
    ViewData["Title"] = "Geleceğin Yönetim Sistemi";
    ViewData["HideSidebar"] = true; // Sidebar'ı bu sayfa için gizle
}

<!-- NEW STICKY NAVBAR -->
<nav class="home-navbar fade-in">
    <div class="nav-container">
        <div class="nav-brand">
            <div class="brand-icon"><i class="bi bi-mortarboard-fill"></i></div>
            <span>StudentMS</span>
        </div>
        <ul class="nav-links">
            <li><a href="#hero">Ana Sayfa</a></li>
            <li><a href="#courseGridAnchor">Kurslar</a></li>
            <li><a href="#whyUs">Neden Biz?</a></li>
        </ul>
        <div class="nav-actions">
            <!-- Theme Toggle Restore -->
            <button class="navbar-icon-btn-premium me-3" id="homeThemeToggle" title="Tema Değiştir">
                <i class="bi bi-moon-stars-fill"></i>
            </button>

            @if (Context.User.Identity != null && Context.User.Identity.IsAuthenticated)
            {
                <a asp-controller="Dashboard" asp-action="Index" class="btn-nav-primary">Panelime Git</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn-nav-outline">Giriş Yap</a>
                <a asp-controller="Account" asp-action="Register" class="btn-nav-primary">Kayıt Ol</a>
            }
        </div>
    </div>
</nav>



<!-- HERO SECTION -->
<div id="hero" class="hero-wrapper full-width">
    <div class="hero-content fade-up">
        <div class="hero-label">
            <span class="badge-innovative">LMS Vision 2026</span>
            <span class="hero-status"><i class="bi bi-circle-fill"></i> Sistem Aktif</span>
        </div>
        
        <h1 class="hero-title-gradient">Geleceğin Eğitim <br/> Deneyimi Burada</h1>
        
        <p class="hero-description-premium">
            Modern öğrenme yöntemleri, interaktif içerikler ve global sertifikalarla kariyerinde bir adım öne geç.
        </p>

        <div class="hero-stats-bar mt-5">
            <div class="stat-item">
                <span class="stat-value">12K+</span>
                <span class="stat-label">Öğrenci</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-value">500+</span>
                <span class="stat-label">Okul</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-value">99.9%</span>
                <span class="stat-label">Memnuniyet</span>
            </div>
        </div>
    </div>

    <div class="hero-visual fade-up delay-1">
        <div class="visual-glow-main"></div>
        <img src="~/images/hero_full_lms.png" alt="Futuristic Abstract Web Design" class="floating-image-premium" />
    </div>
</div>

<div id="whyUs" class="container feature-showcase pt-5 mt-5">
    <div class="section-badge">Neden Biz?</div>
    <h2 class="section-title text-center mb-5">Modern Sorunlara Modern Çözümler</h2>
    
    <div class="innovation-grid">
        <div class="innovation-card fade-up">
            <div class="card-glow"></div>
            <div class="card-icon"><i class="bi bi-cpu-fill"></i></div>
            <h4>Akıllı Veritabanı</h4>
            <p>Verileriniz, .NET 10 mimarisi üzerine kurulu yüksek hızda işlenir.</p>
        </div>
        <div class="innovation-card fade-up delay-1">
            <div class="card-glow primary"></div>
            <div class="card-icon primary"><i class="bi bi-shield-check"></i></div>
            <h4>Gelişmiş Güvenlik</h4>
            <p>JWT ve HttpOnly çerezlerle her zamankinden daha güvendesiniz.</p>
        </div>
        <div class="innovation-card fade-up delay-2">
            <div class="card-glow success"></div>
            <div class="card-icon success"><i class="bi bi-window-stack"></i></div>
            <h4>Innovative UI</h4>
            <p>Göz yormayan karanlık mod ve responsive tasarımıyla her yerde.</p>
        </div>
    </div>
</div>

<div id="courseGridAnchor" class="container course-showcase mt-5 pt-5 pb-5">
    <div class="section-badge">Akademi</div>
    <h2 class="section-title text-center mb-5">Popüler Eğitimlerimiz</h2>
    
    <div class="course-grid" id="courseGrid">
        @foreach (var course in Model)
        {
            <div class="course-card fade-up" data-title="@course.Title.ToLower()" data-category="@course.Category.ToLower()" 
                 onclick="openCourseModal('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(course.Title))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(course.Description))', '@course.ImageUrl')">
                <div class="course-image" style="background-image: url('@course.ImageUrl');"></div>
                <div class="course-content">
                    <div class="course-badge text-white">@course.Category</div>
                    <h4 class="course-title">@course.Title</h4>
                    <div class="course-meta">
                        <span><i class="bi bi-clock"></i> @course.Duration</span>
                        <span><i class="bi bi-star-fill text-warning"></i> @course.Rating.ToString("F1")</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="courseModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content glass-modal text-white">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold text-gradient" id="courseModalName">Kurs Detayı</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      <div class="modal-body p-0">
        <div id="courseModalImage" style="height: 250px; background-size: cover; background-position: center; border-bottom: 1px solid rgba(255,255,255,0.1);"></div>
        <div class="p-5">
            <div class="d-flex align-items-center gap-3 mb-4">
                <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="bi bi-award me-1"></i> Sertifikalı</span>
                <span class="badge" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); px-3 py-2 rounded-pill"><i class="bi bi-laptop me-1"></i> %100 Online</span>
            </div>
            <p id="courseModalDesc" class="text-secondary fs-5" style="line-height:1.7;"></p>
            <div class="d-flex align-items-center gap-3 mt-5 pt-4 border-top border-secondary">
                <button class="btn btn-primary btn-lg rounded-pill px-5 fw-bold" onclick="showToast('Kayıt modülü yapım aşamasında')"><i class="bi bi-cart-plus me-2"></i> Hemen Kayıt Ol</button>
                <button class="btn btn-outline-light btn-lg rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* 1. ELECTRIC BLUE CORE STYLES */
:root {
    --nav-bg: rgba(255, 255, 255, 0.8);
    --nav-text: #0f172a;
    --hero-gradient: linear-gradient(to right, #2563eb 20%, #3b82f6 100%);
}
[data-theme="dark"] :root {
    --nav-bg: rgba(15, 23, 42, 0.8);
    --nav-text: #f8fafc;
    --hero-gradient: linear-gradient(to right, #f8fafc 20%, #60a5fa 100%);
}

.hero-wrapper.full-width {
    width: 100%;
    margin-left: 0;
    padding: 8rem 8% 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 5rem;
    background: var(--bg);
}

/* 2. STICKY NAVBAR (Electric Blue) */
.home-navbar {
    position: fixed;
    top: 1.5rem;
    left: 2rem;
    right: 2rem;
    background: var(--nav-bg);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(59, 130, 246, 0.1);
    border-radius: 1.5rem;
    padding: 0.75rem 2.5rem;
    z-index: 2000;
    transition: 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.05);
}
.nav-container { display: flex; align-items: center; justify-content: space-between; max-width: 1400px; margin: 0 auto; }
.nav-brand { display: flex; align-items: center; gap: 0.75rem; color: var(--nav-text); font-weight: 800; font-size: 1.25rem; }
.brand-icon { width: 36px; height: 36px; background: #3b82f6; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; }
.nav-links { display: flex; list-style: none; gap: 2.5rem; margin: 0; padding: 0; }
.nav-links a { color: var(--text-secondary); font-weight: 600; text-decoration: none; transition: 0.3s; font-size: 0.95rem; }
.nav-links a:hover { color: var(--primary); }
.nav-actions { display: flex; gap: 0.5rem; align-items: center; }

.navbar-icon-btn-premium {
    width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(59, 130, 246, 0.1); background: transparent; color: var(--primary); font-size: 1.2rem; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center;
}
.navbar-icon-btn-premium:hover { background: rgba(59, 130, 246, 0.05); transform: rotate(15deg); }

.btn-nav-primary { background: #3b82f6; color: white !important; padding: 0.6rem 1.5rem; border-radius: 0.75rem; font-weight: 700; text-decoration: none !important; transition: 0.3s; }
.btn-nav-primary:hover { background: #2563eb; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(59, 130, 246, 0.2); }
.btn-nav-outline { border: 1px solid rgba(59, 130, 246, 0.1); color: var(--primary) !important; padding: 0.6rem 1.5rem; border-radius: 0.75rem; font-weight: 600; text-decoration: none !important; transition: 0.3s; }
.btn-nav-outline:hover { background: rgba(59, 130, 246, 0.05); }

/* 4. HERO SECTION STYLES */
.hero-title-gradient { font-size: 5.5rem; letter-spacing: -0.05em; margin-bottom: 2rem; background: var(--hero-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800; }
.hero-description-premium { font-size: 1.35rem; color: var(--text-secondary); max-width: 650px; line-height: 1.6; }

/* 5. COMPONENTS */
.innovation-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; }
.innovation-card { background: var(--bg-card); border: 1px solid var(--border-light); border-radius: 2rem; padding: 3rem; transition: 0.4s; box-shadow: var(--shadow); }
.innovation-card:hover { transform: translateY(-10px); border-color: var(--primary); box-shadow: var(--shadow-lg); }
.card-icon { width: 60px; height: 60px; background: rgba(59, 130, 246, 0.1); color: var(--primary); border-radius: 1rem; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 2rem; }

.section-badge { text-align: center; color: var(--primary); font-weight: 800; text-transform: uppercase; margin-bottom: 1rem; letter-spacing: 2px; }
.section-title { font-size: 3.5rem; font-weight: 800; color: var(--text-primary); margin-bottom: 4rem; letter-spacing: -0.02em; }

.course-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; }
.course-card { background: var(--bg-card); border: 1px solid var(--border-light); border-radius: 2rem; overflow: hidden; transition: 0.4s; cursor: pointer; box-shadow: var(--shadow); }
.course-card:hover { transform: translateY(-15px); border-color: var(--primary); box-shadow: var(--shadow-lg); }
.course-image { height: 220px; background-size: cover; background-position: center; border-bottom: 1px solid var(--border-light); }
.course-content { padding: 2.5rem 2rem; }
.course-badge { background: #3b82f6; padding: 0.4rem 1.25rem; border-radius: 2rem; font-size: 0.75rem; font-weight: 700; margin-bottom: 1rem; display: inline-block; color: white; }
.course-title { font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; }
.course-meta { display: flex; justify-content: space-between; color: var(--text-secondary); font-weight: 600; font-size: 0.875rem; }

.badge-innovative { background: #3b82f6; color: white; padding: 0.5rem 1.25rem; border-radius: 2rem; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
.hero-status { color: #10b981; font-size: 0.8125rem; font-weight: 600; margin-left: 1rem; }

.visual-glow-main { position: absolute; width: 140%; height: 140%; top: -20%; left: -20%; background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%); z-index: -1; filter: blur(60px); }
.floating-image-premium { width: 100%; border-radius: 3rem; box-shadow: 0 40px 100px rgba(0,0,0,0.5); animation: floatingEffect 8s ease-in-out infinite; }

@@keyframes floatingEffect { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-30px); } }

.glass-modal { background: var(--bg-card) !important; backdrop-filter: blur(30px) !important; border: 1px solid var(--border) !important; border-radius: 2rem !important; color: var(--text-primary) !important; }
.text-gradient { background: var(--hero-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

/* RESPONSIVE */
@@media (max-width: 1200px) {
    .home-navbar { top: 0; left: 0; right: 0; border-radius: 0; padding: 1rem 5%; }
    .hero-wrapper.full-width { flex-direction: column; text-align: center; padding-top: 10rem; }
    .hero-content, .hero-visual { max-width: 100%; }
    .hero-title-gradient { font-size: 3.5rem; }
    .nav-links { display: none; }
}
</style>

@section Scripts {
    <script>
        function openCourseModal(title, desc, imageUrl) {
            document.getElementById('courseModalName').innerText = title;
            document.getElementById('courseModalDesc').innerText = desc;
            document.getElementById('courseModalImage').style.backgroundImage = "url('" + imageUrl + "')";
            var myModal = new bootstrap.Modal(document.getElementById('courseModal'));
            myModal.show();
        }

        // Navbar Scroll Effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.home-navbar');
            if (window.scrollY > 50) {
                nav.style.padding = '0.5rem 2.5rem';
                nav.style.top = '0'; nav.style.left = '0'; nav.style.right = '0'; nav.style.borderRadius = '0';
            } else {
                nav.style.padding = '0.75rem 2.5rem';
                nav.style.top = '1.5rem'; nav.style.left = '2rem'; nav.style.right = '2rem'; nav.style.borderRadius = '1.5rem';
            }
        });

        // ---------- THEME TOGGLE FOR HOME (CONFLICT RESOLVED) ----------
        const homeThemeBtn = document.getElementById('homeThemeToggle');
        if (homeThemeBtn) {
            homeThemeBtn.addEventListener('click', () => {
                const current = document.documentElement.getAttribute('data-theme');
                const next = current === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('theme', next);
                updateHomeThemeIcon();
            });
            function updateHomeThemeIcon() {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                homeThemeBtn.querySelector('i').className = isDark ? 'bi bi-sun-fill' : 'bi bi-moon-stars-fill';
            }
            updateHomeThemeIcon();
        }
    </script>
}
